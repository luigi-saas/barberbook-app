generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider     = "postgresql"
  relationMode = "prisma"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  CUSTOMER
  BARBER
  SHOP_OWNER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum PaymentMethod {
  CARD
  CASH
  WALLET
}

enum ShopStatus {
  PENDING_REVIEW
  ACTIVE
  SUSPENDED
  REJECTED
}

enum SubscriptionPlan {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  UNPAID
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_REMINDER
  BOOKING_CANCELLED
  BOOKING_RESCHEDULED
  REVIEW_RECEIVED
  PROMO_OFFER
  SYSTEM
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum WalkInStatus {
  WAITING
  CALLED
  SERVED
  LEFT
}

enum ReviewStatus {
  VISIBLE
  HIDDEN
  FLAGGED
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  clerkId       String    @unique
  role          UserRole  @default(CUSTOMER)
  email         String    @unique
  phone         String?
  firstName     String
  lastName      String
  avatarUrl     String?
  locale        String    @default("fr")
  isVerified    Boolean   @default(false)
  isActive      Boolean   @default(true)
  loyaltyPoints Int       @default(0)
  referralCode  String    @unique @default(cuid())
  referredById  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  referredBy     User?           @relation("Referrals", fields: [referredById], references: [id], onDelete: Restrict, onUpdate: Restrict)
  referrals      User[]          @relation("Referrals")
  barberProfile  Barber?
  ownedShop      Shop?           @relation("ShopOwner")
  bookings       Booking[]       @relation("CustomerBookings")
  reviews        Review[]        @relation("CustomerReviews")
  savedShops     SavedShop[]
  notifications  Notification[]
  loyaltyHistory LoyaltyEntry[]
  supportTickets SupportTicket[]
  adminActions   AdminLog[]      @relation("AdminActions")
  customerNotes  CustomerNote[]  @relation("NoteAboutCustomer")

  @@index([clerkId])
  @@index([email])
  @@index([referredById])
}

model Shop {
  id          String     @id @default(cuid())
  slug        String     @unique
  name        String
  description String?    @db.Text
  logoUrl     String?
  coverUrl    String?
  status      ShopStatus @default(PENDING_REVIEW)
  isFeatured  Boolean    @default(false)
  phone       String?
  email       String?
  website     String?
  address     String?
  city        String?
  country     String     @default("MA")
  latitude    Float?
  longitude   Float?
  ownerId     String     @unique
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  owner             User              @relation("ShopOwner", fields: [ownerId], references: [id])
  barbers           ShopBarber[]
  services          Service[]
  serviceCategories ServiceCategory[]
  bookings          Booking[]
  reviews           Review[]
  gallery           ShopGallery[]
  openingHours      OpeningHours[]
  amenities         ShopAmenity[]
  savedBy           SavedShop[]
  promoCodes        PromoCode[]
  subscription      Subscription?
  walkInQueue       WalkInQueue[]

  @@index([slug])
  @@index([ownerId])
  @@index([city])
  @@index([status])
  @@index([isFeatured])
}

model ShopGallery {
  id        String   @id @default(cuid())
  shopId    String
  imageUrl  String
  caption   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id])

  @@index([shopId])
}

model OpeningHours {
  id        String    @id @default(cuid())
  shopId    String
  dayOfWeek DayOfWeek
  openTime  String
  closeTime String
  isClosed  Boolean   @default(false)

  shop Shop @relation(fields: [shopId], references: [id])

  @@unique([shopId, dayOfWeek])
  @@index([shopId])
}

model ShopAmenity {
  id     String @id @default(cuid())
  shopId String
  name   String

  shop Shop @relation(fields: [shopId], references: [id])

  @@index([shopId])
}

model Barber {
  id           String   @id @default(cuid())
  userId       String   @unique
  bio          String?  @db.Text
  isActive     Boolean  @default(true)
  isVerified   Boolean  @default(false)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user            User                   @relation(fields: [userId], references: [id])
  shops           ShopBarber[]
  services        BarberService[]
  bookings        Booking[]
  availability    BarberAvailability[]
  blockedTimes    BarberBlockedTime[]
  portfolioImages BarberPortfolioImage[]
  reviews         Review[]
  customerNotes   CustomerNote[]

  @@index([userId])
}

model ShopBarber {
  id       String   @id @default(cuid())
  shopId   String
  barberId String
  isOwner  Boolean  @default(false)
  joinedAt DateTime @default(now())

  shop   Shop   @relation(fields: [shopId], references: [id])
  barber Barber @relation(fields: [barberId], references: [id])

  @@unique([shopId, barberId])
  @@index([shopId])
  @@index([barberId])
}

model BarberPortfolioImage {
  id       String  @id @default(cuid())
  barberId String
  imageUrl String
  caption  String?
  order    Int     @default(0)

  barber Barber @relation(fields: [barberId], references: [id])

  @@index([barberId])
}

model BarberAvailability {
  id          String    @id @default(cuid())
  barberId    String
  dayOfWeek   DayOfWeek
  startTime   String
  endTime     String
  isAvailable Boolean   @default(true)

  barber Barber @relation(fields: [barberId], references: [id])

  @@unique([barberId, dayOfWeek])
  @@index([barberId])
}

model BarberBlockedTime {
  id       String   @id @default(cuid())
  barberId String
  startAt  DateTime
  endAt    DateTime
  reason   String?

  barber Barber @relation(fields: [barberId], references: [id])

  @@index([barberId])
  @@index([startAt])
}

model ServiceCategory {
  id     String @id @default(cuid())
  shopId String
  name   String
  order  Int    @default(0)

  shop     Shop      @relation(fields: [shopId], references: [id])
  services Service[]

  @@unique([shopId, name])
  @@index([shopId])
}

model Service {
  id          String   @id @default(cuid())
  shopId      String
  categoryId  String?
  name        String
  description String?  @db.Text
  price       Decimal  @db.Decimal(10, 2)
  duration    Int
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shop         Shop             @relation(fields: [shopId], references: [id])
  category     ServiceCategory? @relation(fields: [categoryId], references: [id])
  barbers      BarberService[]
  bookingItems BookingService[]

  @@index([shopId])
  @@index([categoryId])
}

model BarberService {
  id        String   @id @default(cuid())
  barberId  String
  serviceId String
  price     Decimal? @db.Decimal(10, 2)

  barber  Barber  @relation(fields: [barberId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])

  @@unique([barberId, serviceId])
  @@index([barberId])
  @@index([serviceId])
}

model Booking {
  id                 String        @id @default(cuid())
  customerId         String
  barberId           String
  shopId             String
  status             BookingStatus @default(PENDING)
  scheduledAt        DateTime
  endsAt             DateTime
  customerNotes      String?       @db.Text
  cancellationReason String?       @db.Text
  isWalkIn           Boolean       @default(false)
  rescheduledFromId  String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  customer        User             @relation("CustomerBookings", fields: [customerId], references: [id])
  barber          Barber           @relation(fields: [barberId], references: [id])
  shop            Shop             @relation(fields: [shopId], references: [id])
  rescheduledFrom Booking?         @relation("RescheduledBookings", fields: [rescheduledFromId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  rescheduledTo   Booking[]        @relation("RescheduledBookings")
  services        BookingService[]
  payment         Payment?
  review          Review?
  promo           BookingPromo?

  @@index([customerId])
  @@index([barberId])
  @@index([shopId])
  @@index([scheduledAt])
  @@index([status])
  @@index([rescheduledFromId])
}

model BookingService {
  id        String  @id @default(cuid())
  bookingId String
  serviceId String
  price     Decimal @db.Decimal(10, 2)
  duration  Int

  booking Booking @relation(fields: [bookingId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])

  @@unique([bookingId, serviceId])
  @@index([bookingId])
  @@index([serviceId])
}

model Payment {
  id                    String        @id @default(cuid())
  bookingId             String        @unique
  stripePaymentIntentId String?       @unique
  amount                Decimal       @db.Decimal(10, 2)
  currency              String        @default("MAD")
  status                PaymentStatus @default(PENDING)
  method                PaymentMethod @default(CASH)
  paidAt                DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([stripePaymentIntentId])
}

model Review {
  id         String       @id @default(cuid())
  bookingId  String       @unique
  authorId   String
  barberId   String
  shopId     String
  rating     Int
  comment    String?      @db.Text
  ownerReply String?      @db.Text
  status     ReviewStatus @default(VISIBLE)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id])
  author  User    @relation("CustomerReviews", fields: [authorId], references: [id])
  barber  Barber  @relation(fields: [barberId], references: [id])
  shop    Shop    @relation(fields: [shopId], references: [id])

  @@index([bookingId])
  @@index([barberId])
  @@index([shopId])
  @@index([authorId])
}

model PromoCode {
  id               String       @id @default(cuid())
  shopId           String?
  code             String       @unique
  discountType     DiscountType
  discountValue    Decimal      @db.Decimal(10, 2)
  minBookingAmount Decimal?     @db.Decimal(10, 2)
  maxUsage         Int?
  usageCount       Int          @default(0)
  validFrom        DateTime
  validUntil       DateTime
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())

  shop     Shop?          @relation(fields: [shopId], references: [id])
  bookings BookingPromo[]

  @@index([shopId])
  @@index([code])
}

model BookingPromo {
  id             String  @id @default(cuid())
  bookingId      String  @unique
  promoCodeId    String
  discountAmount Decimal @db.Decimal(10, 2)

  booking   Booking   @relation(fields: [bookingId], references: [id])
  promoCode PromoCode @relation(fields: [promoCodeId], references: [id])

  @@index([bookingId])
  @@index([promoCodeId])
}

model SavedShop {
  id        String   @id @default(cuid())
  userId    String
  shopId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  shop Shop @relation(fields: [shopId], references: [id])

  @@unique([userId, shopId])
  @@index([userId])
  @@index([shopId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  data      Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
}

model LoyaltyEntry {
  id        String   @id @default(cuid())
  userId    String
  points    Int
  reason    String
  bookingId String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model CustomerNote {
  id         String   @id @default(cuid())
  barberId   String
  customerId String
  note       String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  barber   Barber @relation(fields: [barberId], references: [id])
  customer User   @relation("NoteAboutCustomer", fields: [customerId], references: [id])

  @@unique([barberId, customerId])
  @@index([barberId])
  @@index([customerId])
}

model WalkInQueue {
  id                   String       @id @default(cuid())
  shopId               String
  barberId             String?
  customerName         String
  phone                String?
  estimatedWaitMinutes Int?
  status               WalkInStatus @default(WAITING)
  joinedAt             DateTime     @default(now())
  servedAt             DateTime?

  shop Shop @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@index([status])
}

model Subscription {
  id                   String             @id @default(cuid())
  shopId               String             @unique
  stripeSubscriptionId String?            @unique
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(TRIALING)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  shop Shop @relation(fields: [shopId], references: [id])

  @@index([shopId])
}

model SupportTicket {
  id        String              @id @default(cuid())
  userId    String
  subject   String
  category  String?
  status    SupportTicketStatus @default(OPEN)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  user     User             @relation(fields: [userId], references: [id])
  messages SupportMessage[]

  @@index([userId])
  @@index([status])
}

model SupportMessage {
  id        String   @id @default(cuid())
  ticketId  String
  authorId  String
  body      String   @db.Text
  isStaff   Boolean  @default(false)
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id])

  @@index([ticketId])
}

model AdminLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  admin User @relation("AdminActions", fields: [adminId], references: [id])

  @@index([adminId])
  @@index([entityType, entityId])
}
